# Copy this file to ".env" and fill in your real values.
# Never commit your real .env file.

# Your Apify API token (get it from https://console.apify.com/account/integrations)
APIFY_TOKEN=your_apify_token_here

# The Apify Zillow SEARCH actor (returns listing cards for a city / zip / search URL).
# Examples:
#   maxcopell/zillow-scraper
#   epctex/zillow-scraper
APIFY_ACTOR_ID=maxcopell/zillow-scraper

# OPTIONAL: the Apify Zillow DETAIL actor (enriches each property URL with full data).
# Leave empty to skip the detail-enrichment pass.
# Examples:
#   maxcopell/zillow-detail-scraper
#   maxcopell/zillow-api-scraper
APIFY_DETAIL_ACTOR_ID=maxcopell/zillow-detail-scraper

# Optional tuning
# Maximum results to ask the actor for per target (some actors call this "maxItems")
MAX_ITEMS_PER_TARGET=500

# How many minutes to wait for an actor run before giving up
ACTOR_TIMEOUT_MINUTES=15
